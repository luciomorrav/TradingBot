# Copy this file to secrets.env and fill in your keys
# NEVER commit secrets.env to git

# Polymarket — derive API creds from private key using:
#   python -c "from connectors.polymarket_client import PolymarketClient; ..."
#   or set PK env var and use py-clob-client directly
POLY_PRIVATE_KEY=0xYourPolygonWalletPrivateKey
POLY_API_KEY=your_clob_api_key
POLY_API_SECRET=your_clob_api_secret
POLY_API_PASSPHRASE=your_clob_api_passphrase

KALSHI_API_KEY=your_kalshi_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
